{
  "outputDirectory": ".",
  "functions": {
    "api/prices.js": {
      "runtime": "nodejs18.x"
    },
    "api/sheets.js": {
      "runtime": "nodejs18.x"
    },
    "api/search.js": {
      "runtime": "nodejs18.x"
    },
    "api/artwork.js": {
      "runtime": "nodejs18.x"
    },
    "api/recommend.js": {
      "runtime": "nodejs18.x"
    },
    "api/rating.js": {
      "runtime": "nodejs18.x"
    },
    "api/finder.js": {
      "runtime": "nodejs18.x"
    },
    "api/ebay-token.js": {
      "runtime": "nodejs18.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/finder",
      "destination": "/finder.html"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ]
}